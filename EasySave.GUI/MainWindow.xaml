<Window x:Class="EasySave.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasySave.GUI.ViewModels"
        Title="EasySave v2.0"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeep}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Nav button style -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,12"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BgHover}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress bar style -->
        <Style x:Key="SlimProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="{StaticResource BgDeep}"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR                                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,28,20,24">
                    <TextBlock Text="💾 EasySave"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="v2.0 — by ProSoft"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top"
                           Background="{StaticResource BorderBrush}"
                           Margin="16,0,16,12"/>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="10,0">
                    <Button Style="{StaticResource NavBtn}"
                            Content="📋  Backup Jobs"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Jobs"/>
                    <Button Style="{StaticResource NavBtn}"
                            Content="⚙️  Settings"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Status bar at bottom -->
                <Border DockPanel.Dock="Bottom"
                        Margin="12,12,12,16"
                        Background="{StaticResource BgDeep}"
                        CornerRadius="8"
                        Padding="12,8">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">

            <!-- ── JOBS PAGE ────────────────────────────────────────── -->
            <Grid Visibility="{Binding CurrentPage, Converter={x:Static local:PageConverter.Instance}, ConverterParameter=Jobs,
                               FallbackValue=Visible}"
                  xmlns:local="clr-namespace:EasySave.GUI">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="28,22,28,18"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Backup Jobs"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,2,0,0">
                                <Run Text="{Binding JobRows.Count, Mode=OneWay}"/>
                                <Run Text="job(s) configured — unlimited in v2.0"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="▶  Run All"
                                    Style="{StaticResource SuccessBtn}"
                                    Command="{Binding ExecuteAllCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="＋  New Job"
                                    Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding NewJobCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Job list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <ItemsControl ItemsSource="{Binding JobRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Background="{StaticResource BgCard}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="18,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <Border Margin="10,0,0,0"
                                                        Background="{StaticResource Accent}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock Text="{Binding Type}"
                                                               FontSize="10"
                                                               Foreground="White"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondary}">
                                                <Run Text="📁"/>
                                                <Run Text="{Binding Source}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding Target}"/>
                                            </TextBlock>

                                            <ProgressBar Style="{StaticResource SlimProgress}"
                                                         Margin="0,8,0,0"
                                                         Value="{Binding Progress}"
                                                         Maximum="100"/>

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                            <Button Content="▶"
                                                    Style="{StaticResource SuccessBtn}"
                                                    Padding="10,6"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Execute this job"
                                                    Command="{Binding DataContext.ExecuteJobCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Triggers>
                                                    <EventTrigger RoutedEvent="Button.Click">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames
                                                                    Storyboard.TargetProperty="(Button.IsEnabled)">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="False"/>
                                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.05" Value="True"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Button.Triggers>
                                            </Button>
                                            <Button Content="✏"
                                                    Style="{StaticResource GhostBtn}"
                                                    Padding="10,6"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Edit this job"
                                                    Command="{Binding DataContext.SelectJobCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑"
                                                    Style="{StaticResource DangerBtn}"
                                                    Padding="10,6"
                                                    ToolTip="Delete this job"
                                                    Command="{Binding DataContext.DeleteJobCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Create / Edit form -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="24,18">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                     x:Name="NameBox">
                                <TextBox.Tag>Job name</TextBox.Tag>
                            </TextBox>
                            <TextBox Grid.Column="1" Margin="0,0,8,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding FormSource, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" Margin="0,0,8,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding FormTarget, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox Grid.Column="3" Margin="0,0,8,0"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectedIndex="{Binding FormTypeIndex}">
                                <ComboBoxItem Content="Full" Foreground="{StaticResource TextPrimary}"/>
                                <ComboBoxItem Content="Differential" Foreground="{StaticResource TextPrimary}"/>
                            </ComboBox>
                            <Button Grid.Column="4"
                                    Content="Save"
                                    Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding SaveJobCommand}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Name" Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" Width="200" Margin="0,0,8,0"/>
                            <TextBlock Text="Source directory" Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" Width="200" Margin="0,0,8,0"/>
                            <TextBlock Text="Target directory" Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" Width="200" Margin="0,0,8,0"/>
                            <TextBlock Text="Type" Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── SETTINGS PAGE ──────────────────────────────────── -->
            <ScrollViewer Visibility="{Binding CurrentPage,
                              Converter={x:Static local:PageConverter.Instance},
                              ConverterParameter=Settings,
                              FallbackValue=Collapsed}"
                          xmlns:local="clr-namespace:EasySave.GUI"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28,24">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="Settings"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Global configuration for EasySave v2.0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,0,0,28"/>

                    <!-- Log format card -->
                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="20,18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Log Format"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Choose the output format for daily log files."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,4,0,12"/>
                            <ComboBox Style="{StaticResource ModernComboBox}"
                                      SelectedIndex="{Binding LogFormatIndex}"
                                      Width="200" HorizontalAlignment="Left">
                                <ComboBoxItem Content="JSON" Foreground="{StaticResource TextPrimary}"/>
                                <ComboBoxItem Content="XML"  Foreground="{StaticResource TextPrimary}"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Business software card -->
                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="20,18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Business Software"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,4,0,12"
                                       TextWrapping="Wrap">
                                Process name to monitor. If running, backups will be blocked.
                                Leave empty to disable. (e.g. "calc" for Calculator)
                            </TextBlock>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding BusinessSoftware, UpdateSourceTrigger=PropertyChanged}"
                                     Width="300" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Encrypted extensions card -->
                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="20,18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Encrypted Extensions"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,4,0,12"
                                       TextWrapping="Wrap">
                                Comma-separated list of file extensions to encrypt via CryptoSoft
                                after each backup. Leave empty to disable encryption.
                                Example: .txt,.docx,.pdf
                            </TextBlock>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding EncryptedExtensionsText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="300" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Save button -->
                    <Button Content="Save Settings"
                            Style="{StaticResource PrimaryBtn}"
                            HorizontalAlignment="Left"
                            Command="{Binding SaveSettingsCommand}"
                            Padding="20,10"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
